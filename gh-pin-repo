#!/bin/bash

# gh pin-repo - Pin repositories to organization profile
# Note: This requires admin:org scope and org owner permissions
# Usage: gh pin-repo <owner/repo> [owner/repo2] ...

set -e

EXTENSION_NAME="pin-repo"

# Get organization ID
get_org_id() {
    gh api graphql -F query='{ organization(login: "emberlamp") { id } }' --jq '.data.organization.id'
}

# Get repository ID by name
get_repo_id() {
    local repo="$1"
    gh api repos/"$repo" --jq '.id' 2>/dev/null || echo ""
}

# Check if user is org owner
check_org_owner() {
    local org_id="$1"
    local result=$(gh api graphql -F query="query { organization(id: \"$org_id\") { viewerCanUpdatePinnedItems } }" --jq '.data.organization.viewerCanUpdatePinnedItems' 2>/dev/null)
    echo "$result"
}

# List pinned repositories
list_pinned() {
    gh api graphql -F query='{ organization(login: "emberlamp") { pinnedItems(first: 6, types: REPOSITORY) { nodes { ... on Repository { name description url } } } } }' --jq '.data.organization.pinnedItems.nodes[] | "– \(.name): \(.description // "No description")"'
}

# Main
case "$1" in
    --help|-h)
        echo "gh pin-repo - Pin repositories to organization profile"
        echo ""
        echo "Usage:"
        echo "  gh pin-repo <owner/repo> [owner/repo2] ...  Pin repositories"
        echo "  gh pin-repo --list                         List pinned repos"
        echo ""
        echo "Note: You must be an organization owner to pin repos."
        echo "If API doesn't work, pin repos manually at:"
        echo "  https://github.com/emberlamp"
        exit 0
        ;;
    --list)
        list_pinned
        exit 0
        ;;
    "")
        echo "Error: No repository specified"
        echo "Run 'gh pin-repo --help' for usage"
        exit 1
        ;;
    *)
        echo "Note: Pinning via API requires specific GraphQL permissions."
        echo "If this fails, pin repos manually at: https://github.com/emberlamp"
        echo ""
        # Try to list current pinned
        echo "Current pinned repos:"
        list_pinned
        ;;
esac